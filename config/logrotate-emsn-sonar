/home/ronny/emsn-sonar/logs/*.log {
    daily
    rotate 14
    maxsize 500M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    dateext
    dateformat -%Y%m%d-%H%M%S
    su ronny ronny
}

# BattyBirdNET-Analyzer error_log.txt - third-party path maar onze enige
# beheerder. Tijdens incident april 2026 groeide deze ongelimiteerd
# (5226 stack traces sinds 18 april). Geen rotatie betekent op termijn
# disk-vol probleem.
/home/ronny/BattyBirdNET-Analyzer/error_log.txt {
    weekly
    rotate 8
    maxsize 50M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    dateext
    dateformat -%Y%m%d
    su ronny ronny
}
